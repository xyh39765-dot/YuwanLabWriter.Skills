{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yuwanlab.local/schemas/marketplace.schema.json",
  "type": "object",
  "required": [
    "schema_version",
    "generated_at",
    "skills"
  ],
  "properties": {
    "schema_version": {
      "const": "1.0.0"
    },
    "generated_at": {
      "type": "string"
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "name",
          "display_name",
          "version",
          "author_github",
          "description",
          "tags",
          "license",
          "path",
          "entry",
          "checksum_sha256"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "name": {
            "type": "string"
          },
          "display_name": {
            "type": "string"
          },
          "version": {
            "type": "string"
          },
          "author_github": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "tags": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "license": {
            "type": "string"
          },
          "path": {
            "type": "string"
          },
          "entry": {
            "type": "string"
          },
          "checksum_sha256": {
            "type": "string"
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": false
}

