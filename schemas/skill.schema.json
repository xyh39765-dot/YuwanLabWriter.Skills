{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://yuwanlab.local/schemas/skill.schema.json",
  "type": "object",
  "required": [
    "id",
    "name",
    "display_name",
    "version",
    "author",
    "description",
    "tags",
    "license",
    "entry",
    "visibility",
    "runtime",
    "checksum",
    "updated_at"
  ],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.-]+@[A-Za-z0-9_.-]+$"
    },
    "name": {
      "type": "string",
      "minLength": 1
    },
    "display_name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+$"
    },
    "author": {
      "type": "object",
      "required": [
        "github"
      ],
      "properties": {
        "github": {
          "type": "string",
          "pattern": "^[A-Za-z0-9_.-]+$"
        }
      },
      "additionalProperties": true
    },
    "description": {
      "type": "string"
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "license": {
      "type": "string"
    },
    "entry": {
      "type": "string",
      "pattern": "^[A-Za-z0-9_.@/-]+\\.md$"
    },
    "visibility": {
      "const": "public"
    },
    "runtime": {
      "type": "object",
      "required": [
        "kind"
      ],
      "properties": {
        "kind": {
          "const": "instruction-only"
        }
      },
      "additionalProperties": true
    },
    "checksum": {
      "type": "object",
      "required": [
        "sha256"
      ],
      "properties": {
        "sha256": {
          "type": "string"
        }
      }
    },
    "updated_at": {
      "type": "string"
    }
  },
  "additionalProperties": true
}

